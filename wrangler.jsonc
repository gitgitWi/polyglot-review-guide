{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "polyglot-review-guide",
  "compatibility_date": "2026-07-06",
  "compatibility_flags": ["nodejs_compat"],
  // TanStack Start server entry. `vite build` (with @cloudflare/vite-plugin)
  // produces the Worker + prerendered static assets; routing (incl. SSR fallback
  // for any non-prerendered path) is owned by Start, so no _redirects / SPA
  // not_found_handling is needed.
  "main": "@tanstack/react-start/server-entry"
}
