{
  "name": "polyglot-review-guide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun scripts/build-data.mjs && bun run lint && vite build && bun scripts/validate.mjs",
    "dev": "bun scripts/build-data.mjs && vite dev --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "deploy": "bun run build && wrangler deploy",
    "validate": "bun scripts/validate.mjs",
    "typecheck": "bun scripts/build-data.mjs && tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@tanstack/react-router": "^1.114.3",
    "@tanstack/react-start": "^1.168.27",
    "lucide-react": "^0.468.0",
    "marked-react": "^4.0.0",
    "mermaid": "^11.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5",
    "marked": "^18.0.5",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^5.7.2",
    "vite": "^7",
    "wrangler": "^4.107.0"
  },
  "packageManager": "bun@1.3.14"
}
