{
  "name": "polyglot-review-guide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun scripts/build-data.mjs && bun run lint && bun --bun vite build && bun scripts/validate.mjs",
    "dev": "bun scripts/build-data.mjs && bun --bun vite --host 127.0.0.1",
    "preview": "bun --bun vite preview --host 127.0.0.1",
    "validate": "bun scripts/validate.mjs",
    "typecheck": "bun --bun tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@tanstack/react-router": "^1.114.3",
    "lucide-react": "^0.468.0",
    "marked-react": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
